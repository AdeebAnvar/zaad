# Miscellaneous
*.class
*.log
*.hprof
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
**/.dart_tool/
**/.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
**/build/
**/coverage/

# Client (Flutter lives under client/)
client/build/
client/.dart_tool/
installer/output/
# Server (Node.js)
server/node_modules/

# Server local SQLite (runtime / dev data — do not commit)
server/data/*.sqlite
server/data/*.sqlite-shm
server/data/*.sqlite-wal
server/data/*.lock
!server/data/.gitkeep

# Deploy / installer output (avoid committing unpacked artifacts)
**/dist_deploy/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
